{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "dirName": {
      "type": "string"
    },
    "year": {
      "type": "number"
    },
    "role": {
      "type": "string"
    },
    "stack": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "github": {
      "type": "string"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order": {
      "type": "number"
    },
    "featured": {
      "default": true,
      "type": "boolean"
    },
    "status": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "dirName",
    "year",
    "role",
    "stack",
    "description",
    "order",
    "featured"
  ],
  "additionalProperties": false
}