---
import SnsLinks from './SnsLinks.astro';
import { EMAIL, WEBSITE_URL } from '../lib/site';

interface Props {
  showSns?: boolean;
}

const { showSns = false } = Astro.props;
const websiteLabel = WEBSITE_URL.replace(/^https?:\/\//, '');
---
<footer class="footer">
  <div class="footer-inner">
    {showSns && (
      <div class="footer-sns">
        <SnsLinks />
      </div>
    )}
    <p class="footer-copy">
      <span class="footer-copy-item">&copy; はやしごと</span>
      <span class="footer-copy-sep" aria-hidden="true">&mdash;</span>
      <span class="footer-copy-item"><a href={`mailto:${EMAIL}`} class="footer-link">{EMAIL}</a></span>
      <span class="footer-copy-sep" aria-hidden="true">&mdash;</span>
      <span class="footer-copy-item"><a href={WEBSITE_URL} target="_blank" rel="noopener noreferrer" class="footer-link">{websiteLabel}</a></span>
    </p>
  </div>
</footer>
