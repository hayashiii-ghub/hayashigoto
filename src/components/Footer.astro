    )}
    <p class="footer-copy">&copy; はやしごと &mdash; <a href="mailto:hay@shigoto.dev" class="footer-link">hay@shigoto.dev</a> &mdash; <a href="https://shigoto.website" target="_blank" rel="noopener noreferrer" class="footer-link">shigoto.website</a></p>
  </div>
</footer>
