---
import Layout from '../layouts/Layout.astro';
import BudouXText from '../components/BudouXText.astro';
import SnsLinks from '../components/SnsLinks.astro';
import CardViewer from '../components/CardViewer.astro';
import DirSectionHeading from '../components/dir/DirSectionHeading.astro';
import DirEntry from '../components/dir/DirEntry.astro';
import { EMAIL, WEBSITE_URL, HOME_NAV } from '../lib/site';
import { getCollection } from 'astro:content';
const allWorks = await getCollection('works');
const works = allWorks
  .filter((w) => w.data.featured !== false)
  .sort((a, b) => a.data.order - b.data.order);

/* ---------- Tech Stack: worksから自動収集 + 追加ツール ---------- */
const hiddenTech = ['D3.js'];
const worksStacks = [...new Set(allWorks.flatMap((w) => w.data.stack))].filter((t) => !hiddenTech.includes(t));
const extraTools = ['Astro', 'Vercel', 'Vite', 'Figma', 'Codex'];
const allTech = [...new Set([...worksStacks, ...extraTools])];

const mid = Math.ceil(allTech.length / 2);
const track1 = allTech.slice(0, mid);
const track2 = allTech.slice(mid);

const books = [
  { title: 'エピクロス『教説と手紙』', url: 'https://www.amazon.co.jp/dp/4003360613' },
  { title: 'ショーペンハウアー『読書について』', url: 'https://www.amazon.co.jp/dp/4334752713' },
  { title: 'ドストエフスキー『罪と罰』', url: 'https://www.amazon.co.jp/dp/4334751687' },
  { title: 'セネカ『人生の短さについて』', url: 'https://www.amazon.co.jp/dp/4334753507' },
];
---
<Layout title="はやしごと" canonical={`${Astro.site!.origin}/`} nav={HOME_NAV} showFooterSns={true}>
  <Fragment slot="head">
    <link rel="preload" as="image" type="image/webp" href="/logo.webp" />
  </Fragment>

  <div class="loader" id="loader" slot="before-header">
    <div class="loader-text">> loading<span class="loader-dots"></span></div>
  </div>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <h1 class="sr-only">はやしごと - 林 祐太 | Dev & Design</h1>
      <div class="hero-logo">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img src="/logo.png" alt="はやしごと" class="hero-logo-img" width="3200" height="2612" decoding="async" />
        </picture>
        <div class="hero-logo-fallback">はやしごと</div>
      </div>
      <p class="hero-tagline">Web開発 & UXデザイン</p>
      <p class="hero-sub">&mdash; <a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
      <p class="hero-sub">&mdash; <a href={WEBSITE_URL} target="_blank" rel="noopener noreferrer">{WEBSITE_URL.replace(/^https?:\/\//, '')}</a></p>
      <div class="hero-sns">
        <SnsLinks />
      </div>
    </div>
    <div class="scroll-hint" aria-hidden="true">
      <span>scroll</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 4v12M3 12l5 5 5-5"/></svg>
    </div>
  </section>

  <!-- Tech Stack Marquee -->
  <section class="tech-stack">
    <div class="marquee-wrapper">
      <div class="marquee marquee--forward">
        <div class="marquee-track">
          <div class="marquee-content">
            {track1.map((t) => <span>{t}</span>)}
          </div>
        </div>
      </div>
      <div class="marquee marquee--reverse">
        <div class="marquee-track">
          <div class="marquee-content">
            {track2.map((t) => <span>{t}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="dir-section" id="about">
    <div class="dir-section-inner">
      <DirSectionHeading path="/about" controls="about" />

      <div class="dir-tree">
        <DirEntry name="profile.yml">
          <div class="dir-file profile-logo-row"><span class="dir-pipe">│</span><img src="/profile.webp" alt="林 祐太" class="profile-logo" width="240" height="240" loading="lazy" decoding="async" /></div>
          <div class="dir-file"><span class="dir-pipe">│</span><span class="file-label">name:</span><span class="file-value">林 祐太 / yuta hayashi</span></div>
          <div class="dir-file"><span class="dir-pipe">│</span><span class="file-label">brand:</span><span class="file-value">はやしごと</span></div>
          <div class="dir-file"><span class="dir-pipe">│</span><span class="file-label">email:</span><span class="file-value">{EMAIL}</span></div>
          <div class="dir-file"><span class="dir-pipe">│</span><span class="file-label">tag:</span><span class="file-value">04 / INTP</span></div>
        </DirEntry>

        <DirEntry name="philosophy.yml" class="dir-entry--philosophy">
          <div class="dir-file">
            <span class="dir-pipe">│</span><span class="file-label">books:</span><span class="file-value"><a href={books[0].url} target="_blank" rel="noopener noreferrer"><BudouXText text={books[0].title} /></a></span>
          </div>
          {books.slice(1).map((book) => (
            <div class="dir-file">
              <span class="dir-pipe">│</span><span class="file-label" aria-hidden="true"></span><span class="file-value"><a href={book.url} target="_blank" rel="noopener noreferrer"><BudouXText text={book.title} /></a></span>
            </div>
          ))}
        </DirEntry>

        <DirEntry name="meishi/" branch="└──" class="dir-entry--meishi">
          <CardViewer front="/card-front.webp" back="/card-back.webp" orientation="portrait" inline />
        </DirEntry>
      </div>
    </div>
  </section>

  <!-- Works Section -->
  <section class="dir-section" id="works">
    <div class="dir-section-inner">
      <DirSectionHeading path="/works" controls="works" />

      <div class="dir-tree">
        {works.map((work) => (
          <DirEntry name={`${work.data.dirName}/`}>
            <Fragment slot="tags">{work.data.category && <span class="category-tag">{work.data.category}</span>}{work.data.status && <span class="status-tag">{work.data.status}</span>}</Fragment>
            <div class="dir-file"><span class="dir-pipe">│</span><span class="file-value dir-desc"><BudouXText text={work.data.description} /></span></div>
            <div class="dir-file"><span class="dir-pipe">│</span><span class="file-label">stack:</span><span class="file-value">{work.data.stack.map((s) => <span class="tag">{s}</span>)}</span></div>
            <div class="dir-file"><span class="dir-pipe">│</span><a href={`/works/${work.id}`} class="file-more">./README.md →</a></div>
          </DirEntry>
        ))}

        <DirEntry name="more/" branch="└──">
          <div class="dir-file"><span class="dir-pipe">&nbsp;</span><span class="file-value dir-desc"><BudouXText text="その他の制作実績はこちらからご覧いただけます。" /></span></div>
          <div class="dir-file"><span class="dir-pipe">&nbsp;</span><a href="/works" class="file-more">./index.html →</a></div>
        </DirEntry>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="dir-section" id="contact">
    <div class="dir-section-inner">
      <DirSectionHeading path="/contact" controls="contact" />

      <form class="dir-tree contact-form" id="contact-form">
        <div class="hp-field" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="dir-entry cli-reveal" data-toggle>
          <span class="dir-branch">├──</span>
          <span class="dir-name">name.txt</span>
          <div class="dir-expand">
            <div class="dir-file">
              <span class="dir-pipe">│</span>
              <input type="text" id="name" name="name" required placeholder="your name" autocomplete="name" />
            </div>
          </div>
        </div>

        <div class="dir-entry cli-reveal" data-toggle>
          <span class="dir-branch">├──</span>
          <span class="dir-name">email.txt</span>
          <div class="dir-expand">
            <div class="dir-file">
              <span class="dir-pipe">│</span>
              <input type="email" id="email" name="email" required placeholder="your@email.com" autocomplete="email" />
            </div>
          </div>
        </div>

        <div class="dir-entry cli-reveal" data-toggle>
          <span class="dir-branch">├──</span>
          <span class="dir-name">category.sh</span>
          <div class="dir-expand">
            <div class="dir-file">
              <span class="dir-pipe">│</span>
              <select id="category" name="category" required>
                <option value="" disabled selected>select category</option>
                <option value="work">お仕事の相談</option>
                <option value="other">その他</option>
              </select>
            </div>
          </div>
        </div>

        <div class="dir-entry cli-reveal" data-toggle>
          <span class="dir-branch">├──</span>
          <span class="dir-name">message.md</span>
          <div class="dir-expand">
            <div class="dir-file">
              <span class="dir-pipe">│</span>
              <textarea id="message" name="message" rows="5" required placeholder="your message..."></textarea>
            </div>
          </div>
        </div>

        <div class="dir-entry cli-reveal">
          <span class="dir-branch">└──</span>
          <button type="submit" class="dir-submit">./send.sh<span class="cursor-blink">_</span></button>
        </div>
      </form>
    </div>
  </section>

  <script>
    import '../scripts/card.ts';
  </script>
</Layout>
