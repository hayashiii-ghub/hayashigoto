---
import Layout from '../layouts/Layout.astro';

const nav = [
  { href: '/', label: '/home' },
  { href: '/#about', label: '/about' },
  { href: '/#contact', label: '/contact' },
];
---
<Layout
  title="meishi/"
  description="林 祐太の名刺ビューアー — インタラクティブに名刺を閲覧できます"
  nav={nav}
>
  <section class="dir-section work-detail">
    <div class="dir-section-inner">
      <h1 class="cli-line">
        <span class="cli-prompt">></span> <span class="cli-cmd">open</span> <span class="cli-path"><a href="/#about">/about</a>/meishi/</span>
      </h1>

      <div class="card-wrapper" id="card-wrapper">
        <div class="card-canvas" id="card-canvas">
          <div class="card-tilt" id="card-tilt">
            <div class="card-orientation" id="card-orientation" data-orientation="portrait">
              <div class="card-body" id="card-body" data-side="front">
                <div class="card-face card-front">
                  <img src="/card-front.webp" alt="名刺 表面" draggable="false" />
                </div>
                <div class="card-face card-back">
                  <img src="/card-back.webp" alt="名刺 裏面" draggable="false" />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="card-overlay" id="card-overlay" data-orientation="portrait" tabindex="0" aria-label="名刺ビューアー — タップで裏返し、ドラッグで傾き"></div>
      </div>

      <div class="dir-file work-back">
        <a href="/#about" class="file-more">← cd /about</a>
      </div>
    </div>
  </section>

  <script>
    import '../scripts/card.js';
  </script>
</Layout>
