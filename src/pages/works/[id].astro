---
import Layout from '../../layouts/Layout.astro';
import BudouXText from '../../components/BudouXText.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import CliLine from '../../components/works/CliLine.astro';
import DirField from '../../components/works/DirField.astro';
import WorkBackLink from '../../components/works/WorkBackLink.astro';
import CardViewer from '../../components/CardViewer.astro';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { id: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);

const nav = [
  { href: '/', label: '/home' },
  { href: '/#about', label: '/about' },
  { href: '/#works', label: '/works' },
  { href: '/#contact', label: '/contact' },
];
---
<Layout title={`${work.data.dirName}/`} description={work.data.description} canonical={`${Astro.site!.origin}/works/${work.id}`} nav={nav}>
  <section class="dir-section work-detail">
    <div class="dir-section-inner">
      <CliLine variant="heading" cmd="cat"><a href="/#works">/works</a>/{work.data.dirName}/README.md</CliLine>

      <div class="dir-tree">
        <DirField label="title:"><BudouXText text={work.data.title} /></DirField>
        <DirField label="year:">{work.data.year}</DirField>
        <DirField label="role:">{work.data.role}</DirField>
        {work.data.category && (
          <DirField label="category:"><span class="category-tag">{work.data.category}</span></DirField>
        )}
        <DirField label="stack:">{work.data.stack.map((s: string) => <span class="tag">{s}</span>)}</DirField>

        {work.data.url && (
          <CliLine cmd="open"><a href={work.data.url} target="_blank" rel="noopener noreferrer">{work.data.url}</a></CliLine>
        )}

        {work.data.note && (
          <CliLine cmd="note"><a href={work.data.note} target="_blank" rel="noopener noreferrer">{work.data.note}</a></CliLine>
        )}

        {work.data.github && (
          <CliLine cmd="git remote"><a href={work.data.github} target="_blank" rel="noopener noreferrer">{work.data.github}</a></CliLine>
        )}

        {work.data.tools && work.data.tools.map((tool: { name: string; url?: string; github?: string }) => (
          <>
            <CliLine cmd="cd"><span>{tool.name}</span></CliLine>
            {tool.url && (
              <CliLine cmd="open"><a href={tool.url} target="_blank" rel="noopener noreferrer">{tool.url}</a></CliLine>
            )}
            {tool.github && (
              <CliLine cmd="git remote"><a href={tool.github} target="_blank" rel="noopener noreferrer">{tool.github}</a></CliLine>
            )}
          </>
        ))}

        {work.data.images && work.data.images.length > 0 && (
          work.data.imageDisplay === 'cli-link' ? (
            work.data.images.map((img) => (
              <CliLine cmd="open"><a href={img.src} data-lightbox>{img.src.split('/').pop()}</a></CliLine>
            ))
          ) : (
            <div class="work-detail-thumbnails">
              {work.data.images.map((img, i: number) => (
                <Image src={img} alt={`${work.data.title} のプレビュー ${i + 1}`} widths={[400, 800, 1200]} sizes="(max-width: 768px) 100vw, 800px" loading="lazy" decoding="async" />
              ))}
            </div>
          )
        )}

        {work.data.card && (
          <CardViewer
            front={work.data.card.front}
            back={work.data.card.back}
            orientation={work.data.card.orientation}
            altPrefix={work.data.title}
          />
        )}

        <div class="work-detail-body">
          <Content />
        </div>

        <WorkBackLink />
      </div>
    </div>
  </section>

  {work.data.card && (
    <script>
      import '../../scripts/card.ts';
    </script>
  )}
</Layout>
