---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BudouXText from '../../components/BudouXText.astro';
import CliLine from '../../components/dir/CliLine.astro';
import DirEntry from '../../components/dir/DirEntry.astro';
import DirField from '../../components/dir/DirField.astro';
import WorkBackLink from '../../components/dir/WorkBackLink.astro';
import { SUB_NAV } from '../../lib/site';

const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order
);
const workEntries = works.map((work, i) => ({
  work,
  isLast: i === works.length - 1,
}));

// 一覧では /works リンクを除く（現在地のため）
const nav = SUB_NAV.filter((item) => item.href !== '/#works');
---
<Layout title="works/" canonical={`${Astro.site!.origin}/works`} nav={nav}>
  <section class="dir-section work-detail">
    <div class="dir-section-inner">
      <CliLine variant="heading" cmd="ls"><a href="/#works">/works</a></CliLine>

      <div class="dir-tree">
        {workEntries.map(({ work, isLast }) => {
          const pipe = isLast ? '\u00a0' : '│';
          return (
            <DirEntry name={`${work.data.dirName}/`} branch={isLast ? '└──' : '├──'} reveal={false}>
              <Fragment slot="tags">{work.data.category && <span class="category-tag">{work.data.category}</span>}{work.data.status && <span class="status-tag">{work.data.status}</span>}</Fragment>
              <DirField pipe={pipe} valueClass="file-value dir-desc"><BudouXText text={work.data.description} /></DirField>
              <DirField pipe={pipe} label="stack:">{work.data.stack.map((s) => <span class="tag">{s}</span>)}</DirField>
              <div class="dir-file"><span class="dir-pipe">{pipe}</span><a href={`/works/${work.id}`} class="file-more">./README.md →</a></div>
            </DirEntry>
          );
        })}

        <WorkBackLink />
      </div>
    </div>
  </section>
</Layout>
