---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import CliLine from '../../components/works/CliLine.astro';
import DirField from '../../components/works/DirField.astro';
import WorkBackLink from '../../components/works/WorkBackLink.astro';

const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order
);
const workEntries = works.map((work, i) => ({
  work,
  isLast: i === works.length - 1,
}));

const nav = [
  { href: '/', label: '/home' },
  { href: '/#about', label: '/about' },
  { href: '/#contact', label: '/contact' },
];
---
<Layout title="works/" canonical={`${Astro.site!.origin}/works`} nav={nav}>
  <section class="dir-section work-detail">
    <div class="dir-section-inner">
      <CliLine variant="heading" cmd="ls"><a href="/#works">/works</a></CliLine>

      <div class="dir-tree">
        {workEntries.map(({ work, isLast }) => {
          const pipe = isLast ? '\u00a0' : '│';
          return (
            <div class="dir-entry" data-toggle>
              <button type="button" class="dir-entry-toggle" aria-expanded="false">
                <span class="dir-branch">{isLast ? '└──' : '├──'}</span>
                <span class="dir-name">{work.data.dirName}/</span>
              </button>{work.data.category && <span class="category-tag">{work.data.category}</span>}{work.data.status && <span class="status-tag">{work.data.status}</span>}
              <div class="dir-expand">
                <DirField pipe={pipe} valueClass="file-value dir-desc">{work.data.description}</DirField>
                <DirField pipe={pipe} label="stack:">{work.data.stack.map((s: string) => <span class="tag">{s}</span>)}</DirField>
                <div class="dir-file"><span class="dir-pipe">{pipe}</span><a href={`/works/${work.id}`} class="file-more">./README.md →</a></div>
              </div>
            </div>
          );
        })}

        <WorkBackLink />
      </div>
    </div>
  </section>
</Layout>
